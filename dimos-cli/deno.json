{
  "name": "@antim/dimsim",
  "version": "0.1.6",
  "description": "3D simulation environment for the dimos robotics stack. Browser-based Three.js + Rapier sim with LCM transport, sensor publishing, and eval harness.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./cli.ts"
  },
  "publish": {
    "include": [
      "cli.ts",
      "mod.ts",
      "bridge/",
      "eval/",
      "headless/",
      "vendor/",
      "setup.ts"
    ],
    "exclude": ["test/"]
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read --unstable-net bridge/server.ts",
    "eval": "deno run --allow-all cli.ts eval"
  },
  "imports": {
    "@dimos/lcm": "./vendor/lcm/mod.ts",
    "@dimos/msgs": "jsr:@dimos/msgs@^0.2",
    "@std/path": "jsr:@std/path@^1",
    "@std/http": "jsr:@std/http@^1",
    "playwright": "npm:playwright@^1.58"
  }
}
